generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String             @db.VarChar(100)
  domain            String?            @db.VarChar(100)
  brandingSettings  Json               @default("{}") @map("branding_settings")
  attachmentSettings Json              @default("{}") @map("attachment_settings")
  createdAt         DateTime           @default(now()) @map("created_at")
  users             User[]
  tickets           Ticket[]
  auditLogs         AuditLog[]
  assignmentGroups  AssignmentGroup[]
  businessCalendars BusinessCalendar[]
  slaDefinitions    SlaDefinition[]
  attachments       TicketAttachment[]
  serviceCatalogCategories ServiceCatalogCategory[]
  serviceCatalogItems      ServiceCatalogItem[]

  @@map("organizations")
}

model Role {
  id          String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String                @unique @db.VarChar(50)
  description String?
  createdAt   DateTime              @default(now()) @map("created_at")
  users       User[]
  groupRoles  AssignmentGroupRole[]
  userRoles   UserRole[]

  @@map("roles")
}

model User {
  id                         String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId             String                  @map("organization_id") @db.Uuid
  roleId                     String                  @map("role_id") @db.Uuid
  departmentId               String?                 @map("department_id") @db.Uuid
  managerId                  String?                 @map("manager_id") @db.Uuid
  managerRequiredExempt      Boolean                 @default(false) @map("manager_required_exempt")
  name                       String                  @db.VarChar(100)
  email                      String                  @unique @db.VarChar(150)
  phone                      String?                 @db.VarChar(40)
  passwordHash               String                  @map("password_hash")
  createdAt                  DateTime                @default(now()) @map("created_at")
  updatedAt                  DateTime                @default(now()) @map("updated_at")
  active                     Boolean                 @default(true)
  organization               Organization            @relation(fields: [organizationId], references: [id])
  role                       Role                    @relation(fields: [roleId], references: [id])
  manager                    User?                   @relation("UserManager", fields: [managerId], references: [id])
  directReports              User[]                  @relation("UserManager")
  createdTickets             Ticket[]                @relation("TicketCreator")
  assignedTickets            Ticket[]                @relation("TicketAssignee")
  activities                 TicketActivity[]
  auditLogs                  AuditLog[]
  managedAssignmentGroups    AssignmentGroup[]       @relation("AssignmentGroupManager")
  assignmentGroupMemberships AssignmentGroupMember[]
  uploadedAttachments        TicketAttachment[]
  directRoles                UserRole[]              @relation("UserRoleUser")
  grantedRoles               UserRole[]              @relation("UserRoleGrantedBy")
  requestedServiceRequests   ServiceRequest[]        @relation("ServiceRequestRequestedFor")
  approvedServiceApprovals   ServiceApproval[]       @relation("ServiceApprovalApprover")
  specificApprovalRules      ServiceApprovalRule[]   @relation("ServiceApprovalRuleApprover")
  createdRequestTasks        RequestTask[]           @relation("RequestTaskCreator")
  assignedRequestTasks       RequestTask[]           @relation("RequestTaskAssignee")

  @@map("users")
}

model AuditLog {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  tableName      String        @map("table_name") @db.VarChar(100)
  recordId       String        @map("record_id") @db.Uuid
  action         String        @db.VarChar(50)
  oldValue       Json?         @map("old_value")
  newValue       Json?         @map("new_value")
  changedById    String?       @map("changed_by") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at")
  organization   Organization? @relation(fields: [organizationId], references: [id])
  changedBy      User?         @relation(fields: [changedById], references: [id])

  @@index([tableName, recordId])
  @@map("audit_logs")
}

model Status {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  module      String   @db.VarChar(50)
  name        String   @db.VarChar(50)
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  tickets     Ticket[]

  @@unique([module, name])
  @@map("statuses")
}

model TicketType {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String          @unique @db.VarChar(50)
  description    String?
  createdAt      DateTime        @default(now()) @map("created_at")
  tickets        Ticket[]
  slaDefinitions SlaDefinition[]

  @@map("ticket_types")
}

model Priority {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String          @unique @db.VarChar(50)
  level          Int
  description    String?
  createdAt      DateTime        @default(now()) @map("created_at")
  tickets        Ticket[]
  slaDefinitions SlaDefinition[]

  @@map("priorities")
}

model Ticket {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String           @map("organization_id") @db.Uuid
  createdById       String           @map("created_by") @db.Uuid
  assignedToId      String?          @map("assigned_to") @db.Uuid
  departmentId      String?          @map("department_id") @db.Uuid
  ticketNumber      String           @unique @map("ticket_number") @db.VarChar(20)
  title             String           @db.VarChar(200)
  description       String?
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @default(now()) @map("updated_at")
  statusId          String?          @map("status_id") @db.Uuid
  ticketTypeId      String?          @map("ticket_type_id") @db.Uuid
  priorityId        String?          @map("priority_id") @db.Uuid
  assignmentGroupId String?          @map("assignment_group_id") @db.Uuid
  organization      Organization     @relation(fields: [organizationId], references: [id])
  createdBy         User             @relation("TicketCreator", fields: [createdById], references: [id])
  assignedTo        User?            @relation("TicketAssignee", fields: [assignedToId], references: [id])
  status            Status?          @relation(fields: [statusId], references: [id])
  ticketType        TicketType?      @relation(fields: [ticketTypeId], references: [id])
  priority          Priority?        @relation(fields: [priorityId], references: [id])
  assignmentGroup   AssignmentGroup? @relation(fields: [assignmentGroupId], references: [id])
  incident          Incident?
  serviceRequest    ServiceRequest?
  activities        TicketActivity[]
  slas              TicketSla[]
  attachments       TicketAttachment[]

  @@index([organizationId])
  @@index([assignedToId])
  @@index([statusId])
  @@index([assignmentGroupId])
  @@map("tickets")
}

model TicketAttachment {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  ticketId       String       @map("ticket_id") @db.Uuid
  uploadedById   String       @map("uploaded_by") @db.Uuid
  storageKey     String       @unique @map("storage_key") @db.VarChar(500)
  fileName       String       @map("file_name") @db.VarChar(255)
  contentType    String       @map("content_type") @db.VarChar(150)
  sizeBytes      Int          @map("size_bytes")
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ticket         Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy     User         @relation(fields: [uploadedById], references: [id])

  @@index([ticketId, createdAt])
  @@map("ticket_attachments")
}

model AssignmentGroup {
  id             String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String                  @map("organization_id") @db.Uuid
  name           String                  @db.VarChar(100)
  description    String?
  email          String?                 @db.VarChar(150)
  phone          String?                 @db.VarChar(40)
  groupType      String                  @default("FULFILLMENT") @map("group_type") @db.VarChar(30)
  managerId      String?                 @map("manager_id") @db.Uuid
  active         Boolean                 @default(true)
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @default(now()) @map("updated_at")
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  manager        User?                   @relation("AssignmentGroupManager", fields: [managerId], references: [id])
  members        AssignmentGroupMember[]
  tickets        Ticket[]
  roles          AssignmentGroupRole[]
  serviceCatalogItems ServiceCatalogItem[]
  approvalRules        ServiceApprovalRule[]
  requestTasks         RequestTask[]

  @@unique([organizationId, name])
  @@map("assignment_groups")
}

model AssignmentGroupRole {
  assignmentGroupId String          @map("assignment_group_id") @db.Uuid
  roleId            String          @map("role_id") @db.Uuid
  createdAt         DateTime        @default(now()) @map("created_at")
  assignmentGroup   AssignmentGroup @relation(fields: [assignmentGroupId], references: [id], onDelete: Cascade)
  role              Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([assignmentGroupId, roleId])
  @@map("assignment_group_roles")
}

model UserRole {
  userId      String   @map("user_id") @db.Uuid
  roleId      String   @map("role_id") @db.Uuid
  grantedById String?  @map("granted_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation("UserRoleUser", fields: [userId], references: [id], onDelete: Cascade)
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  grantedBy   User?    @relation("UserRoleGrantedBy", fields: [grantedById], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model AssignmentGroupMember {
  assignmentGroupId String          @map("assignment_group_id") @db.Uuid
  userId            String          @map("user_id") @db.Uuid
  createdAt         DateTime        @default(now()) @map("created_at")
  assignmentGroup   AssignmentGroup @relation(fields: [assignmentGroupId], references: [id], onDelete: Cascade)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([assignmentGroupId, userId])
  @@map("assignment_group_members")
}

model Incident {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId        String    @unique @map("ticket_id") @db.Uuid
  impact          String?   @default("LOW") @db.VarChar(20)
  urgency         String?   @default("LOW") @db.VarChar(20)
  affectedService String?   @map("affected_service") @db.VarChar(100)
  resolutionNotes String?   @map("resolution_notes")
  resolvedAt      DateTime? @map("resolved_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  ticket          Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("incidents")
}

model ServiceCatalogCategory {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  name           String               @db.VarChar(100)
  description    String?
  active         Boolean              @default(true)
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @default(now()) @map("updated_at")
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items          ServiceCatalogItem[]

  @@unique([organizationId, name])
  @@map("service_catalog_categories")
}

model ServiceCatalogItem {
  id                        String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId            String                  @map("organization_id") @db.Uuid
  categoryId                String                  @map("category_id") @db.Uuid
  name                      String                  @db.VarChar(120)
  description               String?
  defaultAssignmentGroupId  String?                 @map("default_assignment_group_id") @db.Uuid
  formSchema                Json                    @default("[]") @map("form_schema")
  taskTemplates             Json                    @default("[]") @map("task_templates")
  active                    Boolean                 @default(true)
  createdAt                 DateTime                @default(now()) @map("created_at")
  updatedAt                 DateTime                @default(now()) @map("updated_at")
  organization              Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category                  ServiceCatalogCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  defaultAssignmentGroup    AssignmentGroup?        @relation(fields: [defaultAssignmentGroupId], references: [id])
  serviceRequests           ServiceRequest[]
  approvalRules             ServiceApprovalRule[]

  @@unique([organizationId, name])
  @@index([categoryId])
  @@index([defaultAssignmentGroupId])
  @@map("service_catalog_items")
}

model ServiceRequest {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId         String              @unique @map("ticket_id") @db.Uuid
  requestedForId   String              @map("requested_for") @db.Uuid
  catalogItemId    String              @map("catalog_item_id") @db.Uuid
  requestDetails   Json                @default("{}") @map("request_details")
  fulfillmentNotes String?             @map("fulfillment_notes")
  fulfilledAt      DateTime?           @map("fulfilled_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  ticket           Ticket              @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  requestedFor     User                @relation("ServiceRequestRequestedFor", fields: [requestedForId], references: [id])
  catalogItem      ServiceCatalogItem  @relation(fields: [catalogItemId], references: [id])
  approvals        ServiceApproval[]
  tasks            RequestTask[]

  @@index([catalogItemId])
  @@index([requestedForId])
  @@map("service_requests")
}

model ServiceApprovalRule {
  id                        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  catalogItemId             String              @map("catalog_item_id") @db.Uuid
  sequence                  Int
  approvalType              String              @map("approval_type") @db.VarChar(30)
  approvalGroupId           String?             @map("approval_group_id") @db.Uuid
  specificApproverId        String?             @map("specific_approver_id") @db.Uuid
  required                  Boolean             @default(true)
  active                    Boolean             @default(true)
  createdAt                 DateTime            @default(now()) @map("created_at")
  catalogItem               ServiceCatalogItem  @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  approvalGroup             AssignmentGroup?    @relation(fields: [approvalGroupId], references: [id])
  specificApprover          User?               @relation("ServiceApprovalRuleApprover", fields: [specificApproverId], references: [id])
  approvals                 ServiceApproval[]

  @@index([catalogItemId, sequence])
  @@map("service_approval_rules")
}

model ServiceApproval {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceRequestId String          @map("service_request_id") @db.Uuid
  approvalRuleId   String?         @map("approval_rule_id") @db.Uuid
  sequence         Int
  approvalType     String          @map("approval_type") @db.VarChar(30)
  approverId       String?         @map("approver_id") @db.Uuid
  status           String          @default("PENDING") @db.VarChar(30)
  decisionComment  String?         @map("decision_comment")
  decidedAt        DateTime?       @map("decided_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  serviceRequest   ServiceRequest  @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  approvalRule     ServiceApprovalRule? @relation(fields: [approvalRuleId], references: [id])
  approver         User?           @relation("ServiceApprovalApprover", fields: [approverId], references: [id])

  @@index([serviceRequestId, status])
  @@index([approverId, status])
  @@map("service_approvals")
}

model RequestTask {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceRequestId  String           @map("service_request_id") @db.Uuid
  taskNumber        String           @unique @map("task_number") @db.VarChar(20)
  title             String           @db.VarChar(200)
  description       String?
  assignmentGroupId String?          @map("assignment_group_id") @db.Uuid
  assignedToId      String?          @map("assigned_to") @db.Uuid
  status            String           @default("OPEN") @db.VarChar(30)
  createdById       String           @map("created_by") @db.Uuid
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @default(now()) @map("updated_at")
  completedAt       DateTime?        @map("completed_at")
  serviceRequest    ServiceRequest   @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  assignmentGroup   AssignmentGroup? @relation(fields: [assignmentGroupId], references: [id])
  assignedTo        User?            @relation("RequestTaskAssignee", fields: [assignedToId], references: [id])
  createdBy         User             @relation("RequestTaskCreator", fields: [createdById], references: [id])

  @@index([serviceRequestId])
  @@index([assignmentGroupId, status])
  @@map("request_tasks")
}

model ActivityType {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String           @unique @db.VarChar(50)
  description String?
  activities  TicketActivity[]

  @@map("activity_types")
}

model TicketActivity {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId       String        @map("ticket_id") @db.Uuid
  createdById    String        @map("created_by") @db.Uuid
  comment        String
  createdAt      DateTime      @default(now()) @map("created_at")
  activityTypeId String?       @map("activity_type_id") @db.Uuid
  ticket         Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdBy      User          @relation(fields: [createdById], references: [id])
  activityType   ActivityType? @relation(fields: [activityTypeId], references: [id])

  @@index([ticketId])
  @@map("ticket_activities")
}

model BusinessCalendar {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  name           String          @db.VarChar(100)
  timezone       String          @default("UTC") @db.VarChar(100)
  calendarType   String          @default("TWENTY_FOUR_SEVEN") @map("calendar_type") @db.VarChar(30)
  weeklySchedule Json?           @map("weekly_schedule")
  holidays       Json?           @default("[]")
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @default(now()) @map("updated_at")
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  definitions    SlaDefinition[]

  @@unique([organizationId, name])
  @@map("business_calendars")
}

model SlaDefinition {
  id                      String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId          String           @map("organization_id") @db.Uuid
  name                    String           @db.VarChar(120)
  ticketTypeId            String?          @map("ticket_type_id") @db.Uuid
  priorityId              String?          @map("priority_id") @db.Uuid
  calendarId              String           @map("calendar_id") @db.Uuid
  responseTargetMinutes   Int              @map("response_target_minutes")
  resolutionTargetMinutes Int              @map("resolution_target_minutes")
  pauseStatuses           Json?            @default("[]") @map("pause_statuses")
  version                 Int              @default(1)
  active                  Boolean          @default(true)
  effectiveFrom           DateTime         @default(now()) @map("effective_from")
  createdAt               DateTime         @default(now()) @map("created_at")
  updatedAt               DateTime         @default(now()) @map("updated_at")
  organization            Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ticketType              TicketType?      @relation(fields: [ticketTypeId], references: [id])
  priority                Priority?        @relation(fields: [priorityId], references: [id])
  calendar                BusinessCalendar @relation(fields: [calendarId], references: [id])
  ticketSlas              TicketSla[]

  @@unique([organizationId, name, version])
  @@map("sla_definitions")
}

model TicketSla {
  id                      String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId                String        @map("ticket_id") @db.Uuid
  slaDefinitionId         String        @map("sla_definition_id") @db.Uuid
  definitionName          String        @map("definition_name") @db.VarChar(120)
  definitionVersion       Int           @map("definition_version")
  responseTargetMinutes   Int           @map("response_target_minutes")
  resolutionTargetMinutes Int           @map("resolution_target_minutes")
  startedAt               DateTime      @default(now()) @map("started_at")
  responseDueAt           DateTime      @map("response_due_at")
  resolutionDueAt         DateTime      @map("resolution_due_at")
  firstRespondedAt        DateTime?     @map("first_responded_at")
  resolvedAt              DateTime?     @map("resolved_at")
  pausedAt                DateTime?     @map("paused_at")
  totalPausedSeconds      Int           @default(0) @map("total_paused_seconds")
  status                  String        @default("IN_PROGRESS") @db.VarChar(30)
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @default(now()) @map("updated_at")
  ticket                  Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  definition              SlaDefinition @relation(fields: [slaDefinitionId], references: [id])
  events                  SlaEvent[]

  @@unique([ticketId, slaDefinitionId])
  @@index([status, resolutionDueAt])
  @@map("ticket_slas")
}

model SlaEvent {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketSlaId String    @map("ticket_sla_id") @db.Uuid
  eventType   String    @map("event_type") @db.VarChar(30)
  eventAt     DateTime  @default(now()) @map("event_at")
  details     Json?
  ticketSla   TicketSla @relation(fields: [ticketSlaId], references: [id], onDelete: Cascade)

  @@index([ticketSlaId, eventAt])
  @@map("sla_events")
}
