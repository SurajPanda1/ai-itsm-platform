PORT=3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_itsm?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
CORS_ORIGIN="http://localhost:5173"
# Storage credentials are discovered at runtime. Configure provider/bucket in Admin Console.
# AWS S3: AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY locally, or an IAM role in AWS.
# MinIO/S3-compatible:
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Azure: AZURE_STORAGE_CONNECTION_STRING, or AZURE_STORAGE_ACCOUNT_URL plus managed identity.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_URL=
# Google Cloud: GOOGLE_APPLICATION_CREDENTIALS locally, or workload identity in GCP.
GOOGLE_APPLICATION_CREDENTIALS=
